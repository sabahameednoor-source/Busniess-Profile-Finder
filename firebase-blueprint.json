{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile containing account information and API settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ApiKey": {
      "title": "API Key",
      "description": "Individual API keys generated by users for service interaction.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUsed": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "revoked"] }
      },
      "required": ["key", "ownerId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/apiKeys/{keyId}": {
      "schema": "ApiKey",
      "description": "Central collection of API keys for verification. IDs are the keys themselves or random hashes."
    }
  }
}
